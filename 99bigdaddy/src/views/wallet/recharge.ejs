    <script>
        let MoneyAmountDisplay = document.querySelector("#money_amount_display")
        let ReloadMoneyAmountButton = document.querySelector("#reload_money_amount_button")
        let PaymentMethodOptions = document.querySelector("#payment_methods_options")
        let MoneyAmountInput = document.querySelector("#money_amount_input")
        let QuickMoneyOptions = document.querySelector("#quick_money_options")
        let DepositFundButton = document.querySelector("#deposit_fund_btn")
        let CurrencyChooser = document.querySelector("#currency_chooser")
        let CurrencyLabel = document.querySelector("#currency_label")
        let CurrencySymbol = document.querySelector("#inr_input")
        let CurrencyConversionNote = document.querySelector("#currency_conversion_note")

        const USD_TO_INR_RATE = 82

        const CurrencyMap = {
            INR: "INR",
            USD: "USD",
        }

        const PaymentMethodsMap = {
            UPI_GATEWAY: "upi_gateway",
            WOW_PAY: "wow_pay",
            MANUAL_PAY: "manual_pay",
            USDT_MANUAL: "usdt_manual",
            USDT: "usdt",
        }

        const QuickMoneyForRegular = `
            <div data-v-67caa467="" data-money="500" class="li action">
                <span data-v-67caa467="" class="number">500</span>
            </div>
            <div data-v-67caa467="" data-money="1000" class="li">
                <span data-v-67caa467="" class="number">1K</span>
            </div>
            <div data-v-67caa467="" data-money="2000" class="li">
                <span data-v-67caa467="" class="number">2K</span>
            </div>
            <div data-v-67caa467="" data-money="5000" class="li">
                <span data-v-67caa467="" class="number">5K</span>
            </div>
            <div data-v-67caa467="" data-money="10000" class="li">
                <span data-v-67caa467="" class="number">10K</span>
            </div>
            <div data-v-67caa467="" data-money="100000" class="li">
                <span data-v-67caa467="" class="number">100K</span>
            </div>
            <div data-v-67caa467="" data-money="1000000" class="li">
                <span data-v-67caa467="" class="number">1M</span>
            </div>
        `

        const QuickMoneyForUSD = `
            <div data-v-67caa467="" data-money="5" class="li action">
                <span data-v-67caa467="" class="number">$5</span>
            </div>
            <div data-v-67caa467="" data-money="10" class="li">
                <span data-v-67caa467="" class="number">$10</span>
            </div>
            <div data-v-67caa467="" data-money="25" class="li">
                <span data-v-67caa467="" class="number">$25</span>
            </div>
            <div data-v-67caa467="" data-money="50" class="li">
                <span data-v-67caa467="" class="number">$50</span>
            </div>
            <div data-v-67caa467="" data-money="100" class="li">
                <span data-v-67caa467="" class="number">$100</span>
            </div>
            <div data-v-67caa467="" data-money="500" class="li">
                <span data-v-67caa467="" class="number">$500</span>
            </div>
        `

        let selectedPaymentMethod = ''
        let inputMoney = 0
        let selectedCurrency = CurrencyMap.INR
        const MINIMUM_INR_AMOUNT = 500
        const MINIMUM_USD_AMOUNT = 5

        const getDefaultAmount = () => selectedCurrency === CurrencyMap.USD ? '5' : '500'

        const getQuickMoneyOptions = () => selectedCurrency === CurrencyMap.USD ? QuickMoneyForUSD : QuickMoneyForRegular

        const getPayableMoneyAmount = (amount) => {
            const numericAmount = Number(amount)
            if (!numericAmount || numericAmount <= 0) return 0
            return selectedCurrency === CurrencyMap.USD ? Math.round(numericAmount * USD_TO_INR_RATE) : numericAmount
        }

        const updateCurrencyDisplay = () => {
            const isDollar = selectedCurrency === CurrencyMap.USD
            CurrencyLabel.textContent = isDollar ? 'USD $' : 'INR'
            CurrencySymbol.innerHTML = isDollar ? '$' : '&#8377;'
            MoneyAmountInput.placeholder = isDollar ? 'Please enter amount in dollars' : 'Please enter the amount'
            CurrencyConversionNote.textContent = ''
        }

        const bindQuickMoneyOptions = () => {
            Array.from(QuickMoneyOptions.children).forEach((child) => {
                child.addEventListener("click", handleQuickMoney(child))
            })
        }

        const setDepositAmount = (amount) => {
            inputMoney = Number(amount)
            MoneyAmountInput.value = amount
            updateCurrencyDisplay()
        }

        const alertMessage = (text) => {
            const msg = document.createElement('div');
            msg.setAttribute('data-v-1dcba851', '');
            msg.className = 'msg';

            const msgContent = document.createElement('div');
            msgContent.setAttribute('data-v-1dcba851', '');
            msgContent.className = 'msg-content v-enter-active v-enter-to';
            msgContent.style = '';
            msgContent.textContent = text;

            msg.appendChild(msgContent);
            document.body.appendChild(msg);

            setTimeout(() => {
                msgContent.classList.remove('v-enter-active', 'v-enter-to');
                msgContent.classList.add('v-leave-active', 'v-leave-to');

                setTimeout(() => {
                    document.body.removeChild(msg);
                }, 100);
            }, 1000);
        }


        const handleSetTotalBalance = async () => {
            MoneyAmountDisplay.textContent = "Loading..."

            try {
                const response = await axios.get('/api/webapi/GetUserInfo');
                const user = response?.data?.data

                if (user === null || user === undefined || user?.money_user === undefined || user?.money_user === null) {
                    throw Error("Something went wrong while fetching the user wallet balance!")
                }

                MoneyAmountDisplay.textContent = user?.money_user
            } catch (error) {
                console.log(error)
            }

        }

        const handleCheckAndSelectPaymentMethod = () => {
            let paymentMethodList = Array.from(PaymentMethodOptions.children)

            paymentMethodList = paymentMethodList.filter((item) => {
                return !Array.from(item.classList).includes("disabled")
            })

            let currentPaymentMethod = paymentMethodList.find((item) => {
                return Array.from(item.classList).includes("action")
            })

            selectedPaymentMethod = currentPaymentMethod?.getAttribute("type") || PaymentMethodsMap.MANUAL_PAY
            QuickMoneyOptions.innerHTML = getQuickMoneyOptions()
            setDepositAmount(getDefaultAmount())
            bindQuickMoneyOptions()
        }

        const handleSelectPaymentGateway = (event) => {
            Array.from(PaymentMethodOptions.children).forEach((child) => {
                child.classList.remove("action")
                if (event.currentTarget.getAttribute("type") === child.getAttribute("type")) {
                    child.classList.add("action")
                }
            })

            handleCheckAndSelectPaymentMethod()
        }

        const handleNumericInput = (event) => {
            const key = event.keyCode;
            // Only allow numbers to be entered
            if (key < 48 || key > 57) {
                event.preventDefault();
            }
        }

        const handleMoneyAmountInput = (event) => {
            inputMoney = Number(MoneyAmountInput.value)
            updateCurrencyDisplay()
        }

        const handleQuickMoney = (item) => (event) => {
            const amount = parseInt(item.getAttribute("data-money"))

            setDepositAmount(amount)

            Array.from(QuickMoneyOptions.children).forEach((child) => {
                child.classList.remove("action")
            })

            item.classList.add("action")
        }

        const handleSelectCurrency = (event) => {
            selectedCurrency = event.currentTarget.getAttribute("data-currency") || CurrencyMap.INR

            Array.from(CurrencyChooser.children).forEach((child) => {
                child.classList.toggle("active", child.getAttribute("data-currency") === selectedCurrency)
            })

            QuickMoneyOptions.innerHTML = getQuickMoneyOptions()
            setDepositAmount(getDefaultAmount())
            bindQuickMoneyOptions()
        }

        const handleDepositFund = (event) => {
            const minimumMoneyAllowed = selectedCurrency === CurrencyMap.USD ? MINIMUM_USD_AMOUNT : MINIMUM_INR_AMOUNT

            if (!inputMoney || !(inputMoney >= minimumMoneyAllowed)) {
                const minimumText = selectedCurrency === CurrencyMap.USD ? `$${minimumMoneyAllowed}` : `INR ${minimumMoneyAllowed}`
                alertMessage(`Money is required and it should be ${minimumText} or above!`)
                return
            }

            if (selectedCurrency === CurrencyMap.USD) {
                handleManualUSDTPaymentRequest(inputMoney)
                return
            }

            switch (selectedPaymentMethod) {
                case PaymentMethodsMap.UPI_GATEWAY:
                    handleUPIGatewayPaymentRequest(inputMoney)
                    break;
                case PaymentMethodsMap.WOW_PAY:
                    handleWowPayPaymentRequest(inputMoney)
                    break;
                case PaymentMethodsMap.MANUAL_PAY:
                    handleManualUPIPaymentRequest(inputMoney)
                    break;
                case PaymentMethodsMap.USDT_MANUAL:
                    handleManualUSDTPaymentRequest(inputMoney)
                    break;
                case PaymentMethodsMap.USDT:
                    handleUSDTPaymentRequest(inputMoney)
                    break;
            }
        }

        const handleUPIGatewayPaymentRequest = async (moneyAmount) => {
            try {
                const response = await axios.post("/wallet/paynow/upi", {
                    money: moneyAmount
                });

                const data = response?.data;

                if (data === undefined || data === null) {
                    alertMessage("Something went wrong!");
                    return;
                }

                if (data?.status === false) {
                    alertMessage(data?.message);
                    return;
                }

                window.location.href = data?.urls?.web_url;
            } catch (error) {
                console.error("Payment initiation error:", error);
                if (error.response && error.response.data && error.response.data.message) {
                    alertMessage(error.response.data.message);
                } else {
                    alertMessage("An unexpected error occurred. Please try again later.");
                }
            }
        };

        const handleWowPayPaymentRequest = async (moneyAmount) => {
            try {
                const response = await axios.post(`/wallet/paynow/wowpay?money=${moneyAmount}`)

                const data = response?.data

                if (data === undefined || data === null) {
                    alertMessage("Something went wrong!")
                    return
                }


                if (data?.status === false) {
                    alertMessage(data?.message)
                    return
                }

                window.location.href = data?.payment_url
            } catch (error) {
                console.log(error)
            }
        }

        const handleManualUSDTPaymentRequest = async (moneyAmount) => {
            window.location.href = `/wallet/paynow/manual_usdt?am=${moneyAmount}`
        }

        const handleManualUPIPaymentRequest = async (moneyAmount) => {
            window.location.href = `/wallet/paynow/manual_upi?am=${moneyAmount}`
        }

        const handleUSDTPaymentRequest = async (moneyAmount) => {

        }

        // Below code will run on Page Load 
        handleSetTotalBalance()
        handleCheckAndSelectPaymentMethod()
        handleMoneyAmountInput()
        // --------------------------------

        // Even Listeners
        ReloadMoneyAmountButton.addEventListener("click", handleSetTotalBalance)

        Array.from(PaymentMethodOptions.children).forEach((child) => {
            if (Array.from(child.classList).includes("disabled")) return

            child.addEventListener("click", handleSelectPaymentGateway)
        })

        MoneyAmountInput.addEventListener("input", handleMoneyAmountInput)

        MoneyAmountInput.addEventListener("keypress", handleNumericInput);

        Array.from(CurrencyChooser.children).forEach((child) => {
            child.addEventListener("click", handleSelectCurrency)
        })

        DepositFundButton.addEventListener("click", handleDepositFund);

        /* Some Event Listeners added in handleCheckAndSelectPaymentMethod function */
        // --------------

    </script>
</body>

