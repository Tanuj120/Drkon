        <script>
        let selectedFdPlan = 10;

        function formatMoney(value) {
            return '$' + Number(value || 0).toFixed(2);
        }

        function formatDate(value) {
            if (!value) return '--';
            return new Date(Number(value)).toLocaleString();
        }

        function renderFdSummary(fd) {
            const summary = fd || {
                plans: [],
                history: [],
                lockedAmount: 0,
                withdrawableAmount: 0,
                projectedInterest: 0,
                projectedMaturityAmount: 0
            };

            $('#fdLockedAmount').text(formatMoney(summary.lockedAmount));
            $('#fdWithdrawableAmount').text(formatMoney(summary.withdrawableAmount));
            $('#fdProjectedInterest').text(formatMoney(summary.projectedInterest));
            $('#fdMaturityAmount').text(formatMoney(summary.projectedMaturityAmount));

            const plansHtml = (summary.plans || []).map((plan) => `
                <div class="fd-plan ${Number(plan.days) === Number(selectedFdPlan) ? 'active' : ''}" data-days="${plan.days}">
                    <div class="fd-plan-top">
                        <span>${plan.days} Days</span>
                        <span class="fd-plan-rate">${Number(plan.dailyRate).toFixed(2)}% / day</span>
                    </div>
                    <div class="fd-plan-note">Funds stay locked until the ${plan.days}-day tenure is complete.</div>
                </div>
            `).join('');
            $('#fdPlans').html(plansHtml);

            const history = summary.history || [];
            if (!history.length) {
                $('#fdHistory').html('<div class="fd-empty">No fixed deposits yet.</div>');
                return;
            }

            const historyHtml = history.map((item) => {
                const statusClass = item.status === 'matured' ? 'matured' : '';
                const actionButton = item.status === 'matured'
                    ? `<button class="fd-button secondary fd-withdraw-button" data-id="${item.id}">Withdraw</button>`
                    : '';

                return `
                    <div class="fd-history-item">
                        <div class="fd-history-head">
                            <span>${formatMoney(item.amount)} for ${item.tenureDays} days</span>
                            <span class="fd-history-status ${statusClass}">${item.status}</span>
                        </div>
                        <div class="fd-history-meta">Rate: ${Number(item.dailyRate).toFixed(2)}% daily</div>
                        <div class="fd-history-meta">Projected interest: ${formatMoney(item.totalInterest)}</div>
                        <div class="fd-history-meta">Maturity amount: ${formatMoney(item.maturityAmount)}</div>
                        <div class="fd-history-meta">Start: ${formatDate(item.startTime)}</div>
                        <div class="fd-history-meta">Maturity: ${formatDate(item.maturityTime)}</div>
                        <div style="margin-top:.16rem;">${actionButton}</div>
                    </div>
                `;
            }).join('');

            $('#fdHistory').html(historyHtml);
        }

        function fetchWalletData(showAlertOnFail = false) {
            $.ajax({
                type: "GET",
                url: "/api/webapi/GetUserInfo",
                dataType: "json",
                success: function (response) {
                    if (response.status !== true) {
                        if (showAlertOnFail) {
                            alert(response.message || 'Failed to load wallet');
                        }
                        return;
                    }

                    let user = response.data || {};
                    $('.wallet-user .name').text(user.name_user || '');
                    $('.money').text(formatMoney(user.money_user));
                    $('.balance .item:eq(0) div:eq(1)').text(formatMoney(response.totalWithdraw));
                    $('.balance .item:eq(1) div:eq(1)').text(formatMoney(response.freeBonus));
                    renderFdSummary(response.fixedDeposit);
                },
                error: function () {
                    if (showAlertOnFail) {
                        alert('Failed to load wallet');
                    }
                }
            });
        }

        $('#reload .van-image').click(function (e) {
            e.preventDefault();
            $(this).addClass('action block-click');
            setTimeout(() => {
                $(this).removeClass('action block-click');
            }, 2500);
            fetchWalletData(true);
        });

        $(document).on('click', '.fd-plan', function () {
            selectedFdPlan = Number($(this).data('days'));
            $('.fd-plan').removeClass('active');
            $(this).addClass('active');
        });

        $('#fdCreateButton').click(function () {
            const amount = Number($('#fdAmount').val());
            if (!amount || amount <= 0) {
                alert('Please enter a valid FD amount');
                return;
            }

            $.ajax({
                type: "POST",
                url: "/api/webapi/fd/create",
                data: {
                    amount: amount,
                    tenureDays: selectedFdPlan
                },
                dataType: "json",
                success: function (response) {
                    alert(response.message);
                    if (response.status === true) {
                        $('#fdAmount').val('');
                        fetchWalletData();
                    }
                },
                error: function () {
                    alert('Failed to create FD');
                }
            });
        });

        $(document).on('click', '.fd-withdraw-button', function () {
            const depositId = Number($(this).data('id'));
            $.ajax({
                type: "POST",
                url: "/api/webapi/fd/withdraw",
                data: {
                    depositId: depositId
                },
                dataType: "json",
                success: function (response) {
                    alert(response.message);
                    if (response.status === true) {
                        fetchWalletData();
                    }
                },
                error: function () {
                    alert('Failed to withdraw FD');
                }
            });
        });

        fetchWalletData();
    </script>
