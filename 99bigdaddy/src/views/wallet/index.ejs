<!DOCTYPE html>
<html lang="en" translate="no">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="robots" content="noindex,nofollow">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
    <title>Drakon Wallet</title>
    <link rel="shortcut icon" href="/images/drakon-mark.svg" type="image/x-icon">
    <style>
        :root {
            --bg: #232323;
            --panel: #f7f3ec;
            --card: #ffffff;
            --text: #2a2a2a;
            --muted: #878787;
            --gold-1: #ff875d;
            --gold-2: #ea5b4b;
            --gold-3: #f6d887;
            --line: rgba(0, 0, 0, 0.08);
            --success: #1c9c5a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        .wallet-page {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100vh;
            background: var(--panel);
            padding-bottom: 88px;
        }

        .topbar {
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            color: #fff;
            background: #3f3f3f;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .topbar-button {
            border: 0;
            background: transparent;
            color: inherit;
            font-size: 22px;
            cursor: pointer;
            padding: 6px;
        }

        .topbar-title {
            font-size: 20px;
            font-weight: 700;
        }

        .content {
            padding: 16px;
        }

        .summary-card {
            background: linear-gradient(135deg, var(--gold-1), var(--gold-2));
            color: #fff;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 12px 28px rgba(234, 91, 75, 0.25);
        }

        .summary-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }

        .summary-badge {
            border: 1px solid rgba(255, 255, 255, 0.55);
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .summary-amount {
            font-size: 42px;
            font-weight: 800;
            margin: 0 0 8px;
        }

        .summary-subtitle {
            font-size: 14px;
            opacity: 0.95;
        }

        .metrics {
            background: var(--card);
            margin-top: 16px;
            border-radius: 16px;
            padding: 18px 16px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.06);
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .metric-value {
            font-size: 22px;
            font-weight: 800;
            color: #ef6d58;
        }

        .metric-value.success {
            color: var(--success);
        }

        .metric-label {
            margin-top: 4px;
            color: #676767;
            font-size: 14px;
        }

        .rate-pill {
            display: inline-block;
            margin-top: 8px;
            padding: 6px 12px;
            border: 1px solid #ece3cf;
            border-radius: 999px;
            color: #999;
            font-size: 12px;
        }

        .actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 18px;
        }

        .action-button {
            height: 48px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            border: 1px solid #f0c8ba;
            transition: transform .15s ease;
        }

        .action-button:active {
            transform: scale(0.98);
        }

        .action-button.secondary {
            background: #fff;
            color: #ec775f;
        }

        .action-button.primary {
            border: none;
            background: linear-gradient(90deg, #ff9f7c, #f37059);
            color: #fff;
        }

        .notice {
            margin-top: 14px;
            color: #db785f;
            font-size: 14px;
            line-height: 1.45;
        }

        .learn-link {
            margin-top: 18px;
            text-align: center;
            color: #666;
            font-size: 15px;
        }

        .wallet-page .section {
            margin-top: 18px;
            background: var(--card);
            border-radius: 16px;
            padding: 18px 16px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.06);
            overflow: hidden;
        }

        .transfer-in-panels .section + .section {
            margin-top: 18px;
        }

        .transfer-in-panels {
            display: none;
        }

        .transfer-in-panels.active {
            display: block;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            margin: 0 0 16px;
        }

        .plan-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .plan-card {
            border: 1px solid #efe7d7;
            border-radius: 14px;
            padding: 14px;
            background: #fffdf7;
            cursor: pointer;
        }

        .plan-card.active {
            border-color: #f08b6d;
            box-shadow: 0 6px 18px rgba(240, 139, 109, 0.16);
        }

        .plan-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .plan-rate {
            color: #ef6d58;
        }

        .plan-note {
            color: #7a7a7a;
            font-size: 13px;
        }

        .deposit-form {
            margin-top: 16px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 12px;
        }

        .amount-input {
            height: 48px;
            border-radius: 12px;
            border: 1px solid #e6dfd3;
            padding: 0 14px;
            font-size: 16px;
            width: 100%;
        }

        .records {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .record-card {
            border: 1px solid #f0ece4;
            border-radius: 14px;
            padding: 14px;
            background: #fcfbf8;
        }

        .record-tag {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .record-tag.in {
            background: #ef6d58;
            color: #fff;
        }

        .record-tag.out {
            background: #fff;
            color: #ef6d58;
            border: 1px solid #efb6a8;
        }

        .record-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin: 6px 0;
            font-size: 14px;
        }

        .record-row .label {
            color: #6f6f6f;
        }

        .record-row .value {
            font-weight: 700;
        }

        .record-row .value.green {
            color: var(--success);
        }

        .record-row .value.orange {
            color: #ef8b5c;
        }

        .record-footer {
            margin-top: 10px;
            display: flex;
            justify-content: space-between;
            gap: 12px;
            color: #8a8a8a;
            font-size: 13px;
        }

        .empty-state {
            text-align: center;
            color: #8a8a8a;
            padding: 10px 0 4px;
        }

        .quick-links {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
            margin-top: 18px;
        }

        .quick-link {
            background: #fff;
            border-radius: 14px;
            padding: 12px 8px;
            text-align: center;
            color: #6f6f6f;
            font-size: 12px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
            cursor: pointer;
        }

        .quick-link img {
            width: 30px;
            height: 30px;
            object-fit: contain;
            margin-bottom: 8px;
        }

        .bottom-nav {
            position: fixed;
            left: 50%;
            transform: translateX(-50%);
            bottom: 0;
            width: 100%;
            max-width: 480px;
            background: #2d2d2d;
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            padding: 8px 0 10px;
            border-top: 1px solid rgba(255,255,255,0.08);
            z-index: 15;
        }

        .bottom-nav-item {
            text-align: center;
            color: #a8a8a8;
            font-size: 11px;
            cursor: pointer;
        }

        .bottom-nav-item.active {
            color: var(--gold-3);
            font-weight: 700;
        }

        .bottom-nav-icon {
            display: block;
            font-size: 20px;
            margin-bottom: 4px;
        }
    </style>
</head>
<body>
    <div class="wallet-page">
        <div class="topbar">
            <button class="topbar-button" onclick="window.location='/home'">&#8249;</button>
            <div class="topbar-title">Wallet</div>
            <button class="topbar-button" onclick="window.location='/keFuMenu'">&#9835;</button>
        </div>

        <div class="content">
            <div class="summary-card">
                <div class="summary-head">
                    <div style="font-size:18px;">&#9632;</div>
                    <div class="summary-badge">Financial security</div>
                </div>
                <div class="summary-amount" id="fdLockedAmount">₹0.00</div>
                <div class="summary-subtitle">24-hour estimated revenue <strong id="fdDailyRevenue">₹0.00</strong></div>
            </div>

            <div class="metrics">
                <div class="metrics-grid">
                    <div>
                        <div class="metric-value" id="fdGeneratedRevenue">₹0.00</div>
                        <div class="metric-label">Generated revenue</div>
                        <div class="rate-pill" id="fdRateLabel">My interest rate 1.11</div>
                    </div>
                    <div>
                        <div class="metric-value success" id="fdAccumulatedRevenue">₹0.00</div>
                        <div class="metric-label">Accumulated revenue</div>
                    </div>
                </div>

                <div class="actions">
                    <button class="action-button secondary" id="fdWithdrawAction">Transfer Out</button>
                    <button class="action-button primary" id="fdCreateAction">Transfer In</button>
                </div>

                <div class="notice">Funds are safe and secure, and can be transferred only after the selected Copy Gaming tenure is complete.</div>
                <div class="learn-link">Learn about safes &raquo;</div>
            </div>

            <div class="transfer-in-panels" id="transferInPanels">
                <div class="section">
                    <h2 class="section-title">Copy Gaming</h2>
                    <div class="plan-list" id="fdPlans"></div>
                    <div class="deposit-form">
                        <input id="fdAmount" class="amount-input" type="number" min="500" step="500" placeholder="Enter amount to transfer in">
                        <button class="action-button primary" id="fdCreateButton">Confirm</button>
                    </div>
                </div>

                <div class="section">
                    <h2 class="section-title">Historical records</h2>
                    <div class="records" id="fdHistory"></div>
                </div>
            </div>

            <div class="quick-links">
                <div class="quick-link" onclick="window.location='/wallet/recharge'">
                    <img src="/images/recharge.png" alt="">
                    <div>Deposit</div>
                </div>
                <div class="quick-link" onclick="window.location='/wallet/withdrawal'">
                    <img src="/images/withdraw.png" alt="">
                    <div>Withdraw</div>
                </div>
                <div class="quick-link" onclick="window.location='/wallet/rechargerecord'">
                    <img src="/images/rechargeHistory.png" alt="">
                    <div>Deposit History</div>
                </div>
                <div class="quick-link" onclick="window.location='/wallet/withdrawalrecord'">
                    <img src="/images/withdrawHistory.png" alt="">
                    <div>Withdraw History</div>
                </div>
            </div>
        </div>

        <div class="bottom-nav">
            <div class="bottom-nav-item" onclick="window.location='/home'"><span class="bottom-nav-icon">&#8962;</span>Home</div>
            <div class="bottom-nav-item" onclick="window.location='/checkIn'"><span class="bottom-nav-icon">&#127942;</span>Activity</div>
            <div class="bottom-nav-item" onclick="window.location='/promotion'"><span class="bottom-nav-icon">&#128142;</span>Promotion</div>
            <div class="bottom-nav-item active" onclick="window.location='/wallet'"><span class="bottom-nav-icon">&#128179;</span>Wallet</div>
            <div class="bottom-nav-item" onclick="window.location='/mian'"><span class="bottom-nav-icon">&#128100;</span>Account</div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        let selectedFdPlan = 90;
        let latestFixedDepositSummary = null;

        function formatMoney(value) {
            return '₹' + Number(value || 0).toFixed(2);
        }

        function formatDate(value) {
            if (!value) return '--';
            return new Date(Number(value)).toLocaleDateString() + ' ' + new Date(Number(value)).toLocaleTimeString();
        }

        function notify(message) {
            window.alert(message);
        }

        const defaultCopyGamingPlans = [
            { days: 90, dailyRate: 1.11 }
        ];

        function getCopyGamingPlans(plans) {
            const availablePlans = Array.isArray(plans) && plans.length ? plans : defaultCopyGamingPlans;
            const ninetyDayPlans = availablePlans.filter((plan) => Number(plan.days) === 90);
            return ninetyDayPlans.length ? ninetyDayPlans : defaultCopyGamingPlans;
        }

        function renderPlans(plans) {
            const html = getCopyGamingPlans(plans).map((plan) => `
                <div class="plan-card ${Number(plan.days) === Number(selectedFdPlan) ? 'active' : ''}" data-days="${plan.days}">
                    <div class="plan-top">
                        <span>${plan.days} days Staking</span>
                        <span class="plan-rate">${Number(plan.dailyRate).toFixed(2)}% daily</span>
                    </div>
                    <div class="plan-note">Withdraw only after ${plan.days} full days Staking. Daily payout rate is ${Number(plan.dailyRate).toFixed(2)}%.</div>
                </div>
            `).join('');
            $('#fdPlans').html(html);
        }

        function renderHistory(summary) {
            const history = (summary && summary.history) || [];
            if (!history.length) {
                $('#fdHistory').html('<div class="empty-state">No copy gaming records yet.</div>');
                return;
            }

            const html = history.map((item) => {
                const isWithdrawn = item.status === 'withdrawn';
                const isMatured = item.status === 'matured';
                const tagClass = isWithdrawn ? 'out' : 'in';
                const tagLabel = isWithdrawn ? 'Transfer Out' : 'Transfer In';
                const action = isMatured
                    ? `<button class="action-button secondary fd-withdraw-button" data-id="${item.id}" style="height:40px;margin-top:10px;">Withdraw Matured Copy Gaming</button>`
                    : '';

                return `
                    <div class="record-card">
                        <div class="record-tag ${tagClass}">${tagLabel}</div>
                        <div class="record-row">
                            <span class="label">Amount</span>
                            <span class="value ${isWithdrawn ? 'orange' : 'orange'}">${isWithdrawn ? '-' : '+'}${formatMoney(item.amount)}</span>
                        </div>
                        <div class="record-row">
                            <span class="label">Daily interest rate</span>
                            <span class="value green">${Number(item.dailyRate).toFixed(2)}%</span>
                        </div>
                        <div class="record-row">
                            <span class="label">Payout income</span>
                            <span class="value orange">${formatMoney(item.totalInterest)}</span>
                        </div>
                        <div class="record-row">
                            <span class="label">Maturity amount</span>
                            <span class="value">${formatMoney(item.maturityAmount)}</span>
                        </div>
                        <div class="record-footer">
                            <span>${String(item.id).padStart(10, '0')}</span>
                            <span>${formatDate(item.maturityTime)}</span>
                        </div>
                        ${action}
                    </div>
                `;
            }).join('');

            $('#fdHistory').html(html);
        }

        function renderSummary(summary) {
            latestFixedDepositSummary = summary;
            const activeDeposits = (summary && summary.active) || [];
            const weightedPlan = activeDeposits.length ? activeDeposits[0] : { dailyRate: 1.11 };
            const generatedRevenue = activeDeposits.reduce((total, item) => total + Number(item.earnedInterest || 0), 0);
            const accumulatedRevenue = activeDeposits.reduce((total, item) => total + Number(item.totalInterest || 0), 0);
            const dailyRevenue = activeDeposits.reduce((total, item) => total + ((Number(item.amount || 0) * Number(item.dailyRate || 0)) / 100), 0);

            $('#fdLockedAmount').text(formatMoney(summary ? summary.lockedAmount : 0));
            $('#fdDailyRevenue').text(formatMoney(dailyRevenue));
            $('#fdGeneratedRevenue').text(formatMoney(generatedRevenue));
            $('#fdAccumulatedRevenue').text(formatMoney(accumulatedRevenue));
            $('#fdRateLabel').text(`My interest rate ${Number(weightedPlan.dailyRate || 0).toFixed(2)}`);

            renderPlans(summary ? summary.plans : defaultCopyGamingPlans);
            renderHistory(summary || {});
        }

        function loadWallet() {
            $.ajax({
                type: 'GET',
                url: '/api/webapi/GetUserInfo',
                dataType: 'json',
                timeout: 10000,
                success: function (response) {
                    if (response.status !== true) {
                        notify(response.message || 'Failed to load wallet');
                        return;
                    }
                    renderSummary(response.fixedDeposit || {
                        plans: [
                            { days: 90, dailyRate: 1.11 }
                        ],
                        active: [],
                        history: [],
                        lockedAmount: 0,
                        projectedInterest: 0,
                        projectedMaturityAmount: 0,
                        withdrawableAmount: 0
                    });
                },
                error: function () {
                    notify('Wallet data is not responding properly.');
                }
            });
        }

        function createFd() {
            const amount = Number($('#fdAmount').val());
            if (!amount || amount <= 0) {
                notify('Please enter a valid amount.');
                return;
            }
            if (amount % 500 !== 0) {
                notify('Amount must be in multiples of 500.');
                return;
            }

            $.ajax({
                type: 'POST',
                url: '/api/webapi/fd/create',
                dataType: 'json',
                data: {
                    amount,
                    tenureDays: selectedFdPlan
                },
                success: function (response) {
                    notify(response.message);
                    if (response.status === true) {
                        $('#fdAmount').val('');
                        renderSummary(response.data);
                    }
                },
                error: function () {
                notify('Copy Gaming transfer in failed.');
            }
        });
        }

        function withdrawMaturedFd(depositId) {
            $.ajax({
                type: 'POST',
                url: '/api/webapi/fd/withdraw',
                dataType: 'json',
                data: {
                    depositId
                },
                success: function (response) {
                    notify(response.message);
                    if (response.status === true) {
                        renderSummary(response.data);
                    }
                },
                error: function () {
                notify('Copy Gaming transfer out failed.');
            }
        });
        }

        $(document).on('click', '.plan-card', function () {
            selectedFdPlan = Number($(this).data('days'));
            if (latestFixedDepositSummary) {
                renderSummary(latestFixedDepositSummary);
            }
        });

        $('#fdCreateButton').on('click', createFd);
        $('#fdCreateAction').on('click', function () {
            $('#transferInPanels').addClass('active');
            document.getElementById('transferInPanels').scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        $('#fdWithdrawAction').on('click', function () {
            const matured = ((latestFixedDepositSummary && latestFixedDepositSummary.history) || []).find((item) => item.status === 'matured');
            if (!matured) {
                notify('No matured Copy Gaming is available for transfer out yet.');
                return;
            }
            withdrawMaturedFd(matured.id);
        });

        $(document).on('click', '.fd-withdraw-button', function () {
            withdrawMaturedFd(Number($(this).data('id')));
        });

        loadWallet();
    </script>
</body>
</html>
