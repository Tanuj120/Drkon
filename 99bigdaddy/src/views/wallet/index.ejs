            margin-bottom: .08rem;
        }

        .fd-stat-value {
            font-size: .36rem;
            color: #8f5206;
            font-weight: 700;
        }

        .fd-plans {
            display: flex;
            flex-direction: column;
            gap: .18rem;
            margin-bottom: .26rem;
        }

        .fd-plan {
            border: 1px solid #f1d58d;
            border-radius: .2rem;
            padding: .22rem;
            background: #fffdf7;
            cursor: pointer;
        }

        .fd-plan.active {
            border-color: #d9a23b;
            background: linear-gradient(135deg, #fff3cf, #fffdf8);
            box-shadow: 0 0.06rem 0.18rem rgba(217, 162, 59, 0.18);
        }

        .fd-plan-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: .08rem;
            font-weight: 700;
            color: #754200;
        }

        .fd-plan-rate {
            color: #e67e22;
        }

        .fd-plan-note {
            font-size: .24rem;
            color: #7c7c7c;
        }

        .fd-form {
            display: flex;
            gap: .18rem;
            align-items: stretch;
            margin-bottom: .28rem;
        }

        .fd-input {
            flex: 1;
            border: 1px solid #e3e3e3;
            border-radius: .18rem;
            padding: 0 .22rem;
            font-size: .32rem;
            min-height: .96rem;
        }

        .fd-button {
            border: none;
            border-radius: .18rem;
            padding: 0 .34rem;
            min-height: .96rem;
            background: linear-gradient(90deg, #ffd01e, #ff8917);
            color: #6a3b00;
            font-weight: 700;
            font-size: .3rem;
            cursor: pointer;
        }

        .fd-button.secondary {
            min-height: .74rem;
            padding: 0 .28rem;
            font-size: .26rem;
        }

        .fd-history {
            display: flex;
            flex-direction: column;
            gap: .18rem;
        }

        .fd-history-item {
            border: 1px solid #f1f1f1;
            border-radius: .18rem;
            padding: .22rem;
            background: #fafafa;
        }

        .fd-history-head {
            display: flex;
            justify-content: space-between;
            gap: .16rem;
            font-weight: 700;
            color: #5f5f5f;
            margin-bottom: .08rem;
        }

        .fd-history-meta {
            font-size: .24rem;
            color: #868686;
            line-height: 1.5;
        }

        .fd-history-status {
            color: #e67e22;
            text-transform: capitalize;
        }

        .fd-history-status.matured {
            color: #2e8b57;
        }

        .fd-empty {
            color: #8d8d8d;
            font-size: .28rem;
            text-align: center;
            padding: .25rem 0;
        }
    </style>
</head>

