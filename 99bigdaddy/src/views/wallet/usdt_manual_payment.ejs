<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manual Deposit</title>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.7/axios.min.js"
        integrity="sha512-NQfB/bDaB8kaSXF8E77JjhHG5PM6XVRxvHzkZiwl3ddWCEPBa23T76MuWSwAJdMGJnmQqM0VeY9kFszsrBEFrQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer">
        </script>
</head>

<body>
    <style>
        html {
            min-height: 100%;
            width: 100%;
            overflow-x: hidden;
            box-sizing: border-box;
        }

        *,
        *::before,
        *::after {
            box-sizing: inherit;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100%;
            width: 100%;
            overflow-x: hidden;
            background: #eaf6ff;
        }

        main {
            display: flex;
            flex-direction: column;
            gap: 15px;
            min-height: 100vh;
            height: auto;
            width: 100%;
            max-width: 550px;
            margin-left: auto;
            margin-right: auto;
            overflow-x: hidden;
            padding-bottom: 30px;
        }

        header {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #f2f2f2;
            padding: 6px;
            border-radius: 12px;
            margin: 15px 10px;
            width: calc(100% - 20px);
            flex-shrink: 0;
        }

        footer {
            background-color: #f2f2f2;
            padding: 6px;
            text-align: center;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
            margin: 0px 10px;
            margin-top: auto;
        }

        .tutorial_root {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #f2f2f2;
            padding: 0px 25px 20px;
            border-radius: 12px;
            margin: 15px 10px;
            width: calc(100% - 20px);
            flex-shrink: 0;
        }

        .tutorial_content p {
            display: flex;
            gap: 6px;
        }

        .tutorial_content p strong {
            white-space: nowrap;
        }

        @media (min-width: 500px) {
            .tutorial_root {
                padding: 0px 20px 20px;
            }
        }

        .upi_display_root {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #f2f2f2;
            padding: 0px 25px 20px;
            border-radius: 12px;
            margin: 15px 10px;
            width: calc(100% - 20px);
            overflow: visible;
            flex-shrink: 0;
        }

        .upi_display_root h2 {
            margin: 20px 0px 5px;
            font-weight: 600;
            text-align: center;
        }

        .upi_display_content {
            width: 100%;
            max-width: 440px;
            margin-top: 10px;
            padding: 12px 13px;
            min-height: 52px;
            border-radius: 9px;
            border: 1px solid #ccc;
            font-size: 14px;
            cursor: pointer;
            background: #fff;
            overflow: visible;
            position: relative;
            padding-right: 36px;
        }

        .upi_display_content p {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 6px;
            width: 100%;
            margin: 0;
        }

        .upi_display_content p strong {
            flex: 0 0 auto;
            white-space: nowrap;
        }

        #wallet_address_field {
            min-width: 0;
            flex: 1 1 auto;
            overflow-wrap: anywhere;
            word-break: break-all;
            text-align: center;
        }

        .upi_display_content__img {
            display: none;
        }

        .wallet-address-card {
            width: 100%;
            max-width: 440px;
            margin-top: 14px;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid #d8d8d8;
            background: #fff;
            color: #111;
            font-size: 14px;
            font-weight: 700;
            line-height: 1.45;
            text-align: center;
            overflow-wrap: anywhere;
            word-break: break-all;
        }

        .qr-code-frame {
            width: 320px;
            height: 320px;
            max-width: calc(100vw - 80px);
            max-height: calc(100vw - 80px);
            margin-top: 14px;
            background: #fff;
            border-radius: 8px;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        .qr-code-frame svg,
        .qr-code-image {
            width: 100%;
            height: 100%;
            min-width: 100%;
            min-height: 100%;
            display: block;
            object-fit: contain;
        }

        .qr-code-frame svg {
            background: #fff;
        }

        .qr-code-fallback-text {
            display: none;
            margin-top: 8px;
            color: #555;
            font-size: 13px;
            text-align: center;
        }

        .verification_form__root {
            display: flex;
            flex-direction: column;
            gap: 6px;
            /* align-items: center; */
            background: #f2f2f2;
            padding: 10px 25px 25px;
            border-radius: 12px;
            margin: 15px 10px;
            width: calc(100% - 20px);
            flex-shrink: 0;
        }

        .verification_form__root label {
            margin-top: 10px;
            font-weight: 600;
        }

        .verification_form__root input {
            margin-top: 10px;
            padding: 10px 13px;
            border-radius: 9px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

        .verification_form__root input::placeholder {
            font-size: 14px;
        }

        .verification_form__root button {
            margin-top: 10px;
            padding: 10px;
            border-radius: 9px;
            border: 1px solid #ccc;
            background-color: #1c4ff7;
            background: linear-gradient(90deg,
                    rgba(172, 10, 154, 1) 0%,
                    rgba(0, 39, 255, 1) 100%);

            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        .upi_pay_now {
            margin-top: 10px;
            padding: 10px 15px;
            border-radius: 9px;
            border: 1px solid #ccc;
            background-color: #1c4ff7;
            background: linear-gradient(40deg,
                    rgba(172, 10, 154, 1) 0%,
                    rgba(0, 39, 255, 1) 100%);
            font-weight: 500;
            color: white;
            font-size: 16px;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
        }

        @media (max-width: 420px) {
            main {
                gap: 10px;
            }

            header,
            .upi_display_root,
            .verification_form__root,
            .tutorial_root {
                margin-left: 8px;
                margin-right: 8px;
                width: calc(100% - 16px);
            }

            .upi_display_root,
            .verification_form__root,
            .tutorial_root {
                padding-left: 16px;
                padding-right: 16px;
            }

            .upi_display_title {
                font-size: 24px;
            }

            .qr-code-frame {
                width: 280px;
                height: 280px;
                max-width: calc(100vw - 64px);
                max-height: calc(100vw - 64px);
                padding: 8px;
            }

            .qr-code-image {
                width: 100%;
                height: 100%;
            }

            .wallet-address-card,
            .upi_display_content {
                font-size: 13px;
            }
        }
    </style>

    <main>
        <header>
            <h2>Manual Deposit</h2>
        </header>

        <div class="upi_display_root">
            <h2 class="upi_display_title">Send <%=Amount%> USDT on</h2>
            <button class="upi_display_content" id="copy_wallet_address_btn">
                <p>
                    <strong>Wallet Address: </strong>
                    <span id="wallet_address_field">
                        <%=UsdtWalletAddress%>
                    </span>

                    <img class="upi_display_content__img"
                        src="data:image/svg+xml;base64,"
                        alt="copy upi id" />
                </p>
            </button>
            <div class="qr-code-frame" id="qr_code_frame">
                <img
                    src="/index_files/qr.jpeg"
                    alt="Bep20 USDT QR Code"
                    class="qr-code-image"
                    width="300"
                    height="300"
                    style="width: 100%; height: 100%; min-width: 100%; min-height: 100%; display: block; object-fit: contain;"
                    onerror="document.getElementById('qr_fallback_text').style.display='block';"
                >
            </div>
            <div class="qr-code-fallback-text" id="qr_fallback_text">If QR does not load, copy the wallet address below.</div>
            <div class="wallet-address-card" id="wallet_address_display"><%=UsdtWalletAddress%></div>
            <a href="/index_files/qr.jpeg" download="bep20-usdt-qr.jpeg" class="upi_pay_now">Download QR Code</a>
        </div>

        <form class="verification_form__root" id="transaction_hash_form" action="#" method="post">
            <label for="ref_no">Transaction Hash No.</label>
            <input type="text" id="ref_no" name="ref_no" required maxlength="191" autocapitalize="off" spellcheck="false" placeholder="Enter Transaction Hash no." />
            <button id="submit_button" type="submit">Submit</button>
        </form>

        <div class="tutorial_root">
            <h3 class="tutorial_title">Step by Step Process</h3>
            <div class="tutorial_content">
                <p>
                    <strong>Step 1: </strong>
                    <span>
                        Open your Bep20 Usdt Wallet and click on the "Send" option.
                    </span>
                </p>
                <p>
                    <strong>Step 2:</strong>
                    <span>
                        Enter our Wallet address as a receiver and the amount you want to send.
                    </span>
                </p>
                <p>
                    <strong>Step 3:</strong>
                    <span>
                        Click on the "Send" button to complete the transaction.
                    </span>
                </p>
                <p>
                    <strong>Step 4:</strong>
                    <span>
                        Copy the Transaction Hash No. and paste it in our Transaction Hash field.
                    </span>
                </p>
                <p>
                    <strong>Step 5:</strong>
                    <span> Click on the "Submit" button to complete the process. </span>
                </p>
            </div>
        </div>

        <footer>
            <p></p>
        </footer>
    </main>

    <script>

        const alertMessage = (text) => {
            const msg = document.createElement('div');
            msg.setAttribute('data-v-1dcba851', '');
            msg.className = 'msg';

            const msgContent = document.createElement('div');
            msgContent.setAttribute('data-v-1dcba851', '');
            msgContent.className = 'msg-content v-enter-active v-enter-to';
            msgContent.style = '';
            msgContent.textContent = text;

            msg.appendChild(msgContent);
            document.body.appendChild(msg);

            setTimeout(() => {
                msgContent.classList.remove('v-enter-active', 'v-enter-to');
                msgContent.classList.add('v-leave-active', 'v-leave-to');

                setTimeout(() => {
                    document.body.removeChild(msg);
                }, 100);
            }, 1000);
        }

        const copyUpiId = document.getElementById("copy_wallet_address_btn");

        copyUpiId.addEventListener("click", function () {
            let upi_id = document.getElementById("wallet_address_field").innerText.trim();
            console.log(upi_id);
            navigator.clipboard.writeText(upi_id);
            alertMessage("Wallet address copied");
        });

        const submitButton = document.getElementById("submit_button");
        const transactionHashForm = document.getElementById("transaction_hash_form");
        const isValidTransactionHash = (hash) => {
            return /^0x[a-fA-F0-9]{64}$/.test(hash) || /^[A-Za-z0-9][A-Za-z0-9._:-]{5,190}$/.test(hash);
        }

        transactionHashForm.addEventListener("submit", async (event) => {
            try {
                event.preventDefault();
                const refNoInput = document.getElementById("ref_no");
                const refNo = refNoInput.value.trim();
                const amount = '<%=Amount%>';
                if (!refNo) {
                    alertMessage("Please enter Transaction Hash No.");
                    return;
                }
                if (!isValidTransactionHash(refNo)) {
                    alertMessage("Please enter a valid Transaction Hash No.");
                    return;
                }
                refNoInput.value = refNo;
                submitButton.disabled = true;
                submitButton.textContent = "Submitting...";
                const response = await axios.post("/wallet/paynow/manual_usdt_request", {
                    money: amount,
                    utr: refNo,
                })

                if (!response?.data) {
                    alertMessage("Something went Wrong!")
                    return
                }

                if (response?.data?.status === false) {
                    alertMessage(response?.data?.message)
                    return
                }

                alertMessage(response?.data?.message)

                window.location.href = "/wallet/rechargerecord"
            } catch (error) {
                console.log(error);
                alertMessage(error?.response?.data?.message || "Something went Wrong!")
            } finally {
                submitButton.disabled = false;
                submitButton.textContent = "Submit";
            }
        });
    </script>
</body>

</html>
