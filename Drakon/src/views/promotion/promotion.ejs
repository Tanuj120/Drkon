    <script>
        $(document).ready(function () {
            function alertMess(text, sic) {
                $('body').append(
                    `
					<div data-v-1dcba851="" class="msg">
						<div data-v-1dcba851="" class="msg-content v-enter-active v-enter-to" style=""> ${text} </div>
					</div>
					`
                );
                setTimeout(() => {
                    $('.msg .msg-content').removeClass('v-enter-active v-enter-to');
                    $('.msg .msg-content').addClass('v-leave-active v-leave-to');
                    setTimeout(() => {
                        $('.msg').remove();
                    }, 100);
                    if (sic && typeof sic.removeClass === 'function') {
                        sic.removeClass('block-click');
                    }
                }, 1000);
            }

            function fallbackCopyText(text) {
                const temp = document.createElement('textarea');
                temp.value = text;
                temp.setAttribute('readonly', '');
                temp.style.position = 'fixed';
                temp.style.top = '0';
                temp.style.left = '0';
                temp.style.width = '1px';
                temp.style.height = '1px';
                temp.style.opacity = '0.01';
                temp.style.pointerEvents = 'none';
                temp.style.zIndex = '-1';
                document.body.appendChild(temp);

                const selection = window.getSelection && window.getSelection();
                if (selection) {
                    selection.removeAllRanges();
                }

                temp.focus();
                temp.select();
                temp.setSelectionRange(0, text.length);
                const copied = document.execCommand('copy');
                document.body.removeChild(temp);

                if (selection) {
                    selection.removeAllRanges();
                }

                return copied;
            }

            function setCopyButtonLoading($button) {
                if ($button && typeof $button.addClass === 'function') {
                    $button.addClass('block-click');
                }
            }

            async function copyText(text, $button) {
                const value = String(text || '').trim();
                if (!value) {
                    alertMess('Nothing to copy', $button);
                    return;
                }

                try {
                    if (navigator.clipboard && window.isSecureContext) {
                        await navigator.clipboard.writeText(value);
                    } else if (!fallbackCopyText(value)) {
                        throw new Error('Fallback copy failed');
                    }
                    alertMess('Copy successful', $button);
                } catch (error) {
                    if (fallbackCopyText(value)) {
                        alertMess('Copy successful', $button);
                    } else {
                        alertMess('Copy failed', $button);
                    }
                }
            }

            window.copyTextValue = copyText;
            window.copy = function (selector) {
                copyText($(selector).text(), null);
            }

            $('.btn-box .btn').click(function (e) {
                e.preventDefault();
                const $button = $(this);
                setCopyButtonLoading($button);
                copyText($button.attr('data-clipboard-text'), $button);
            });

            $('#copy_invite_link').click(function (e) {
                e.preventDefault();
                copyText($('#invite_code').text(), null);
            });
        });
    </script>
    <script>
        function RosesRender(datas) {
            let html = datas.map((e) => {
                let html = '';
                return html += `<div data-v-7c8bbbf4="" class="bd van-row">
                        <div data-v-7c8bbbf4="" class="c-tc van-ellipsis van-col van-col--6">Lvl ${e.level}</div>
                        <div data-v-7c8bbbf4="" class="c-tc van-col van-col--4">${e.f1}%</div>
                        <div data-v-7c8bbbf4="" class="c-tc van-col van-col--4">${e.f2}%</div>
                        <div data-v-7c8bbbf4="" class="c-tc van-col van-col--5">${e.f3}%</div>
                        <div data-v-7c8bbbf4="" class="c-tc van-col van-col--5">${e.f4}%</div>
                    </div>`;
            });
            $('.table:eq(1) .box').append(html);

            $('.table:eq(1) .box').append(`
                <div data-v-7c8bbbf4="" class="bd van-row">
                    <div data-v-7c8bbbf4="" class="c-tc fw van-col van-col--6">...</div>
                    <div data-v-7c8bbbf4="" class="c-tc fw van-col van-col--4">...</div>
                    <div data-v-7c8bbbf4="" class="c-tc fw van-col van-col--4">...</div>
                    <div data-v-7c8bbbf4="" class="c-tc fw van-col van-col--5">...</div>
                    <div data-v-7c8bbbf4="" class="c-tc fw van-col van-col--5">...</div>
                </div>
                `);
        }
        $.ajax({
            type: "POST",
            url: "/api/webapi/promotion",
            data: {

            },
            dataType: "json",
            success: function (response) {
                if (!response || response.status === false || !response.invite || !response.info || !response.info[0]) {
                    return;
                }
                $('#f1').text(response.invite.f1);
                $('#f1_today').text(response.invite.f1_today);
                const f1Count = response.invite.f1_today;
                console.log(f1Count);
                $('#f_all_today').text(response.invite.f_all_today);
                $('#f_total').text(response.invite.total_f);

                $('#roses_f').text("Team Commission: " + response.invite.roses_f);
                $('#roses_all').text(response.invite.roses_all);
                $('#roses_today').text(response.invite.roses_today);
                const inviteCode = String(response.info[0].code || '').trim();
                const inviteLink = `${window.location.origin}/register?r_code=${encodeURIComponent(inviteCode)}`;
                $('#invite_code').text(inviteLink);

                RosesRender(response.level);
                $('.btn-box .btn:eq(0)').attr('data-clipboard-text', inviteCode);
                $('.btn-box .btn:eq(1)').attr('data-clipboard-text', inviteLink);
                var qrcode = new QRCode("qrcode");
                $('#qrcode').attr('title', inviteLink)
                function makeCode() {
                    qrcode.makeCode(inviteLink);
                }

                makeCode();
            },
            error: function () {
                console.error('Failed to load promotion data');
            },
            complete: function () {
                $('.Loading').fadeOut(0);
            }
        });

        function copy(selector) {
            if (window.copyTextValue) {
                window.copyTextValue($(selector).text(), null);
            }
        }
    </script>
